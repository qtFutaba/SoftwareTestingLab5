    {
      "name": "http://localhost:8080/api/students",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Response is valid JSON\", function () {\r",
              "    // This check runs BEFORE parsing\r",
              "    // This way you can identify protocol issues clearly without\r",
              "    // mixing them up with functionality issues.\r",
              "    pm.response.to.be.withBody;\r",
              "    pm.response.to.be.json; \r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array of Students\", function() {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "    pm.expect(jsonData.length).to.be.at.least(1);\r",
              "})\r",
              "\r",
              "pm.test(\"Response has the correct name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    var firstStudent = jsonData[0];\r",
              "    // var student = jsonData.find(s=> s.name === \"Sherlock Holmes\");\r",
              "    // pm.expect(student).to.not.be.undefined;\r",
              "    pm.expect(firstStudent.name).to.eql(\"Sherlock Holmes\");\r",
              "    pm.expect(firstStudent.major).to.eql(\"Computer Science\");\r",
              "    pm.expect(firstStudent.gpa).to.eql(4.0);\r",
              "});\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
