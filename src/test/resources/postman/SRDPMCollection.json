  "item": [
    {
      "name": "Add Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is valid JSON\", function () {\r",
              "    // This check runs BEFORE parsing\r",
              "    // This way you can identify protocol issues clearly without\r",
              "    // mixing them up with functionality issues.\r",
              "    pm.response.to.be.withBody;\r",
              "    pm.response.to.be.json; \r",
              "});\r",
              "\r",
              "pm.test(\"Response has the correct name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.message).to.contains(\"Sherlock Holmes\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"Sherlock Holmes\",\r\n    \"major\": \"Computer Science\",\r\n    \"gpa\": 4.0\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://{{base_url}}/api/students",
          "protocol": "http",
